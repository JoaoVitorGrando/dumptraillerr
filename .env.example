# =============================================================================
# FAGU Home Services — environment variables
# =============================================================================
# Copy this file to `.env` and fill in the values you have.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# =============================================================================

# --- GoHighLevel webhooks ----------------------------------------------------
# Create one inbound webhook per form in GHL (Automation > Workflows > Inbound
# Webhook trigger). The form sends a JSON payload like:
#   {
#     formType: "owner_signup" | "customer_signup" | "driver_signup"
#              | "booking" | "contact",
#     submittedAt, source, page, referrer,
#     data: { ...form fields with the same name attributes }
#   }
# When a variable is empty, the form runs in DEMO mode (no network call).
VITE_GHL_BOOKING_WEBHOOK=
VITE_GHL_OWNER_WEBHOOK=
VITE_GHL_CUSTOMER_WEBHOOK=
VITE_GHL_DRIVER_WEBHOOK=
VITE_GHL_CONTACT_WEBHOOK=

# --- Stripe ------------------------------------------------------------------
# Used by the (future) prepayment flow. The publishable key is safe to ship
# to the browser; the checkout endpoint should point at your own backend
# (or a serverless function) that creates a Stripe Checkout Session.
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_CHECKOUT_ENDPOINT=

# --- Google Maps -------------------------------------------------------------
# Optional. Enables address autocomplete and route preview on the booking
# form once the maps integration is wired up.
VITE_GOOGLE_MAPS_KEY=

# --- Public contact info -----------------------------------------------------
# Falls back to placeholder values if not provided.
VITE_CONTACT_PHONE=
VITE_CONTACT_EMAIL=
VITE_CONTACT_HOURS=
